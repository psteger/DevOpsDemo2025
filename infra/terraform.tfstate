            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "\"applicationSet\":\n  \"enabled\": true\n\"configs\":\n  \"cm\":\n    \"application.instanceLabelKey\": \"argocd.argoproj.io/instance\"\n    \"url\": \"https://argocd.local\"\n  \"params\":\n    \"server.insecure\": true\n\"controller\":\n  \"metrics\":\n    \"enabled\": true\n\"global\":\n  \"domain\": \"argocd.local\"\n\"repoServer\":\n  \"metrics\":\n    \"enabled\": true\n\"server\":\n  \"ingress\":\n    \"enabled\": false\n  \"service\":\n    \"annotations\":\n      \"service.beta.kubernetes.io/aws-load-balancer-scheme\": \"internet-facing\"\n      \"service.beta.kubernetes.io/aws-load-balancer-type\": \"nlb\"\n    \"type\": \"LoadBalancer\"\n"
            ],
            "verify": false,
            "version": "9.1.7",
            "wait": true,
            "wait_for_jobs": false
          },
